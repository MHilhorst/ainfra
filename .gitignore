# Build output
/dist/
/ainfra
*.test

# Personal layer — per-developer, never committed. Anchored to the repo root
# only, so the tracked examples/ illustrations are not accidentally ignored.
/ainfra.personal.yaml
/ainfra.personal.lock

# The example ships a committed ainfra.personal.yaml as an illustration, but
# its personal lock is generated by `ainfra lock` and must not be committed.
/examples/multi-database/ainfra.personal.lock

# Generated JSON Schema (produced by `ainfra schema`).
ainfra.schema.json

# Resolved/generated runtime state
/.ainfra/

# Local Claude Code state (worktrees, session settings) — never committed
/.claude/

# Go
/vendor/

# OS
.DS_Store

# Docs site (VitePress)
/node_modules/
/package-lock.json
/docs/.vitepress/dist/
/docs/.vitepress/cache/
# Synced at build time from /spec
/docs/spec/
.vercel
